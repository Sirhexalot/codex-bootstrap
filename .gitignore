.DS_Store

# Editor settings
.vscode/
.idea/

# Local environment files
.env
.env.*

# Logs
*.log

# Node / frontend artifacts
node_modules/
dist/
build/

# Python artifacts
.venv/
venv/
__pycache__/
*.pyc

# Local Claude notes
.claude/*.local.md

# Bootstrap-local state
# Customer-facing files created by `codex init` live in the visible parent folder.
# They are intentionally outside the hidden `.codex` runtime and therefore not tracked there:
#   ../Agents.md
#   ../Memory.md
#   ../Decisions.md
AGENTS.md
Agents.md
Memory.md
Decisions.md
.codex/state/tools/*.env
.codex/state/skills/*.env
.codex/state/mcps/*.env
.codex/runtime/tools/*
!.codex/runtime/tools/.gitkeep
!.codex/runtime/tools/bin/
!.codex/runtime/tools/documents/
.codex/runtime/skills/*
!.codex/runtime/skills/.gitkeep
!.codex/runtime/skills/README.md
!.codex/runtime/skills/cache/
.codex/runtime/skills/cache/*
!.codex/runtime/skills/cache/.gitkeep
.codex/runtime/skills/**/.skill-source.env
.codex/runtime/mcps/**/.mcp-source.env
